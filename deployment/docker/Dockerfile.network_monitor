FROM python:3.12-slim

# Network diagnostic tools used by the agent's tools.py
RUN apt-get update && apt-get install -y --no-install-recommends \
    net-tools \
    iproute2 \
    iputils-arping \
    bind9-dnsutils \
    lsof \
    procps \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Run only the network_monitor agent (not the full pipeline)
CMD ["python", "-m", "scripts.run_network_monitor"]
